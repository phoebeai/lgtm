{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoebe.ai/schemas/lgtm-config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "reviewers"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "minLength": 1
        },
        "effort": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reviewers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "display_name",
          "prompt_file",
          "scope"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "prompt_file": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
