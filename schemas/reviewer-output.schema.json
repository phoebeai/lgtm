{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reviewer",
    "run_state",
    "summary",
    "resolved_finding_ids",
    "new_findings",
    "errors"
  ],
  "properties": {
    "reviewer": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "minLength": 1
    },
    "run_state": {
      "type": "string",
      "enum": [
        "completed",
        "skipped",
        "error"
      ]
    },
    "summary": {
      "type": "string"
    },
    "resolved_finding_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "new_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "file",
          "line",
          "recommendation"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "file": {
            "type": [
              "string",
              "null"
            ]
          },
          "line": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "recommendation": {
            "type": "string"
          },
          "reopen_finding_id": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
